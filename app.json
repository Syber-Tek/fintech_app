{
  "expo": {
    "name": "FinTech",
    "slug": "FinTech",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/AppIcon@2x.png",
    "scheme": "fintech",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "n",
      "icon": "./assets/AppIcon@2x.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ic_launcher.png",
        "backgroundColor": "#007b4b"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.sybertek.fintech"
    },
    "web": {
      "output": "static",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#007b4b",
          "dark": {
            "backgroundColor": "#007b4b"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "852c3fae-50ff-4e39-9299-a2e5371fb825"
      }
    }
  }
}
